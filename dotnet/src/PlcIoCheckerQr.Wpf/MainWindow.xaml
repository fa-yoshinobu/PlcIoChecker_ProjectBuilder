<Window x:Class="PlcIoCheckerQr.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PlcIoCheckerQr.Wpf"
        Title="PLC IO Checker Project Builder"
        Width="1320"
        Height="900"
        Icon="/icon.ico"
        MinWidth="1120"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}">

  <Window.Resources>
    <local:UppercaseTextConverter x:Key="UppercaseTextConverter"/>
    <DataTemplate x:Key="UppercaseComboBoxItemTemplate">
      <TextBlock Text="{Binding Converter={StaticResource UppercaseTextConverter}}"/>
    </DataTemplate>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="38"/>
    </Grid.RowDefinitions>

    <!-- Row 0: standard menu -->
    <Menu Grid.Row="0"
          Background="{StaticResource HeaderBg}"
          Foreground="{StaticResource TextMain}"
          AutomationProperties.AutomationId="MainMenu">
      <MenuItem x:Name="_fileMenu" Header="File" AutomationProperties.AutomationId="FileMenu">
        <MenuItem x:Name="_loadJsonMenuItem" Header="Load JSON"
                  AutomationProperties.AutomationId="LoadJsonMenuItem"
                  Click="LoadJson_Click"/>
        <MenuItem x:Name="_saveJsonMenuItem" Header="Save JSON"
                  AutomationProperties.AutomationId="SaveJsonMenuItem"
                  Click="SaveJson_Click"/>
        <MenuItem x:Name="_showJsonMenuItem" Header="Show JSON"
                  AutomationProperties.AutomationId="ShowJsonMenuItem"
                  Click="ShowJson_Click"/>
      </MenuItem>
      <MenuItem x:Name="_qrMenu" Header="QR" AutomationProperties.AutomationId="QrMenu"
                ToolTip="Configure QR chunking, display size, and error correction level. Compression is fixed to Zstd.">
        <MenuItem x:Name="_qrChunkSizeMenu" Header="Chunk size"
                  AutomationProperties.AutomationId="QrChunkSizeMenu"
                  ToolTip="Characters per QR page. Smaller values create more pages but easier-to-read QR codes.">
          <MenuItem Header="350 chars/page" Tag="chunk:350" IsCheckable="True" Click="QrOptionMenuItem_Click"
                    ToolTip="Prioritizes scan reliability. Creates more pages, but each QR code is coarser."/>
          <MenuItem Header="500 chars/page" Tag="chunk:500" IsCheckable="True" Click="QrOptionMenuItem_Click"
                    ToolTip="Leans toward easier scanning. Uses slightly more pages with coarser QR codes."/>
          <MenuItem Header="800 chars/page" Tag="chunk:800" IsCheckable="True" Click="QrOptionMenuItem_Click"
                    ToolTip="Default setting. Balances page count and scan readability."/>
          <MenuItem Header="1200 chars/page" Tag="chunk:1200" IsCheckable="True" Click="QrOptionMenuItem_Click"
                    ToolTip="For minimizing page count. QR codes become denser and may be harder to scan."/>
        </MenuItem>
        <MenuItem x:Name="_qrDisplaySizeMenu" Header="Display size"
                  AutomationProperties.AutomationId="QrDisplaySizeMenu"
                  ToolTip="QR image size on screen. Adjust for the scanner device and display size.">
          <MenuItem Header="600 px" Tag="size:600" IsCheckable="True" Click="QrOptionMenuItem_Click"
                    ToolTip="Small display size. Use when screen space is limited."/>
          <MenuItem Header="800 px" Tag="size:800" IsCheckable="True" Click="QrOptionMenuItem_Click"
                    ToolTip="Medium display size. Suitable for typical laptop screens."/>
          <MenuItem Header="1000 px" Tag="size:1000" IsCheckable="True" Click="QrOptionMenuItem_Click"
                    ToolTip="Default setting. Prioritizes scan readability."/>
          <MenuItem Header="1200 px" Tag="size:1200" IsCheckable="True" Click="QrOptionMenuItem_Click"
                    ToolTip="Large display size. Use when scanning from farther away."/>
        </MenuItem>
        <MenuItem x:Name="_qrErrorCorrectionMenu" Header="Error correction"
                  AutomationProperties.AutomationId="QrErrorCorrectionMenu"
                  ToolTip="Recovery strength when a QR code is partly damaged or dirty. Higher levels recover better but make the QR denser.">
          <MenuItem Header="L" Tag="ec:L" IsCheckable="True" Click="QrOptionMenuItem_Click"
                    ToolTip="Recovers up to about 7%. Best for screen display, with the coarsest and easiest-to-scan QR code."/>
          <MenuItem Header="M" Tag="ec:M" IsCheckable="True" Click="QrOptionMenuItem_Click"
                    ToolTip="Recovers up to about 15%. Balanced for normal use."/>
          <MenuItem Header="Q" Tag="ec:Q" IsCheckable="True" Click="QrOptionMenuItem_Click"
                    ToolTip="Recovers up to about 25%. Use for printing or when some dirt is expected."/>
          <MenuItem Header="H" Tag="ec:H" IsCheckable="True" Click="QrOptionMenuItem_Click"
                    ToolTip="Recovers up to about 30%. Stronger recovery, but the QR code becomes denser and may be harder to scan."/>
        </MenuItem>
      </MenuItem>
      <MenuItem x:Name="_helpMenu" Header="Help" AutomationProperties.AutomationId="HelpMenu">
        <MenuItem x:Name="_aboutMenuItem" Header="About"
                  AutomationProperties.AutomationId="AboutMenuItem"
                  Click="AboutMenuItem_Click"/>
      </MenuItem>
    </Menu>

    <!-- Row 1: navigation bar -->
    <Border Grid.Row="1" Background="{StaticResource NavBg}">
      <Grid Height="88">

        <!-- Editor navigation -->
        <Grid x:Name="_navInputArea">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Orientation="Horizontal"
                      VerticalAlignment="Center" Margin="24,0,0,0">
            <Image Source="/icon.ico"
                   Width="64"
                   Height="64"
                   Margin="0,0,14,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="PLC IO Checker"
                       Foreground="{StaticResource NavFg}"
                       FontWeight="SemiBold" FontSize="15"
                       VerticalAlignment="Center"/>
            <TextBlock Text=" Project Builder"
                       Foreground="{StaticResource NavFgMuted}"
                       FontSize="15"
                       VerticalAlignment="Center"/>
            <TextBlock Text=" — "
                       Foreground="{StaticResource NavHover}"
                       FontSize="15" Margin="8,0"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="_headerProjectName"
                       Foreground="{StaticResource NavFgMuted}"
                       FontSize="13"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="360"/>
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Horizontal"
                      VerticalAlignment="Center" Margin="0,0,20,0">
            <Button x:Name="_langButton"
                    Style="{StaticResource NavOutlineButton}"
                    Margin="0,0,10,0"
                    FontSize="12"
                    Click="LangButton_Click">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x1F310; " FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="_langLabel" Text="EN" FontSize="12" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button x:Name="_generateQrButton"
                    Content="QR  Generate QR"
                    Style="{StaticResource PrimaryButton}"
                    Click="Generate_Click"/>
          </StackPanel>
        </Grid>

        <!-- QR navigation -->
        <Grid x:Name="_navQrArea" Visibility="Collapsed">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <Button x:Name="_backToEditorButton"
                  Grid.Column="0"
                  Content="&lt;-  Back to editor"
                  Style="{StaticResource NavGhostButton}"
                  Margin="12,0,0,0"
                  Click="BackToEditor_Click"/>

          <StackPanel Grid.Column="1" Orientation="Vertical"
                      Margin="18,0" VerticalAlignment="Center">
            <TextBlock Text="QR"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource NavFg}"/>
            <TextBlock x:Name="_pageLabel"
                       Foreground="{StaticResource ErrorFg}"
                       FontSize="15"
                       FontWeight="Bold"
                       TextTrimming="CharacterEllipsis"/>
          </StackPanel>

          <StackPanel Grid.Column="2" Orientation="Horizontal"
                      VerticalAlignment="Center" Margin="0,0,20,0">
            <Button x:Name="_prevQrButton"
                    Content="&lt;-  Previous"
                    Style="{StaticResource NavGhostButton}"
                    Margin="0,0,4,0"
                    Click="PrevQr_Click"/>
            <Button x:Name="_nextQrButton"
                    Content="Next  -&gt;"
                    Style="{StaticResource NavGhostButton}"
                    Margin="0,0,12,0"
                    Click="NextQr_Click"/>
            <Button x:Name="_saveQrImagesButton"
                    Content="v  Save PNG"
                    Style="{StaticResource AppButton}"
                    Click="SaveQrImages_Click"/>
          </StackPanel>
        </Grid>

      </Grid>
    </Border>

    <!-- Row 2: content -->
    <Grid x:Name="_inputView" Grid.Row="2">
      <TabControl x:Name="_mainTabs">
        <TabItem x:Name="_devicesTab" Header="Devices">
          <Border Style="{StaticResource PanelBorder}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,20,0">
                  <TextBlock x:Name="_devicesTitle" Text="Devices" Style="{StaticResource SectionTitle}"/>
                  <TextBlock x:Name="_devicesMeta" Text="Edit addresses and data types." Style="{StaticResource SectionMeta}"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                  <Button x:Name="_moveDeviceUpButton"
                          Content="^  Up"
                          Style="{StaticResource GhostButton}"
                          ToolTip="Move selected device rows up. Alt+Up also works."
                          Margin="0,0,8,0"
                          Click="MoveDeviceUp_Click"/>
                  <Button x:Name="_moveDeviceDownButton"
                          Content="v  Down"
                          Style="{StaticResource GhostButton}"
                          ToolTip="Move selected device rows down. Alt+Down also works."
                          Margin="0,0,8,0"
                          Click="MoveDeviceDown_Click"/>
                  <Button x:Name="_addDeviceButton"
                          Content="+  Add row"
                          Style="{StaticResource AppButton}"
                          Margin="0,0,8,0"
                          Click="AddDevice_Click"/>
                  <TextBox x:Name="_deviceBlockStart"
                           Width="86"
                           Text="D00"
                           ToolTip="Block start address"
                           Margin="0,0,6,0"/>
                  <TextBox x:Name="_deviceBlockCount"
                           Width="54"
                           Text="10"
                           ToolTip="Block point count"
                           Margin="0,0,8,0"/>
                  <Button x:Name="_addDeviceBlockButton"
                          Content="+  Block"
                          Style="{StaticResource AppButton}"
                          Margin="0,0,8,0"
                          Click="AddDeviceBlock_Click"/>
                  <Button x:Name="_deleteDeviceButton"
                          Content="-  Delete"
                          Style="{StaticResource GhostButton}"
                          Click="DeleteDevice_Click"/>
                </StackPanel>
              </Grid>

              <DataGrid x:Name="_devicesGrid"
                        Grid.Row="2"
                        AlternationCount="2"/>
            </Grid>
          </Border>
        </TabItem>

        <TabItem x:Name="_watchTab" Header="Time Chart">
          <Border Style="{StaticResource PanelBorder}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,20,0">
                  <TextBlock x:Name="_watchTitle" Text="Time Chart Targets" Style="{StaticResource SectionTitle}"/>
                  <TextBlock x:Name="_watchMeta" Text="Choose addresses shown in the mobile app time chart, up to 20." Style="{StaticResource SectionMeta}"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                  <Button x:Name="_moveWatchUpButton"
                          Content="^  Up"
                          Style="{StaticResource GhostButton}"
                          ToolTip="Move selected time chart rows up. Alt+Up also works."
                          Margin="0,0,8,0"
                          Click="MoveWatchUp_Click"/>
                  <Button x:Name="_moveWatchDownButton"
                          Content="v  Down"
                          Style="{StaticResource GhostButton}"
                          ToolTip="Move selected time chart rows down. Alt+Down also works."
                          Margin="0,0,8,0"
                          Click="MoveWatchDown_Click"/>
                  <Button x:Name="_addWatchButton"
                          Content="+  Add row"
                          Style="{StaticResource AppButton}"
                          Margin="0,0,8,0"
                          Click="AddWatch_Click"/>
                  <TextBox x:Name="_watchBlockStart"
                           Width="86"
                           Text="X0"
                           ToolTip="Block start address"
                           Margin="0,0,6,0"/>
                  <TextBox x:Name="_watchBlockCount"
                           Width="54"
                           Text="16"
                           ToolTip="Block point count"
                           Margin="0,0,8,0"/>
                  <Button x:Name="_addWatchBlockButton"
                          Content="+  Block"
                          Style="{StaticResource AppButton}"
                          Margin="0,0,8,0"
                          Click="AddWatchBlock_Click"/>
                  <Button x:Name="_deleteWatchButton"
                          Content="-  Delete"
                          Style="{StaticResource GhostButton}"
                          Click="DeleteWatch_Click"/>
                </StackPanel>
              </Grid>

              <DataGrid x:Name="_watchGrid"
                        Grid.Row="2"
                        AlternationCount="2"/>
            </Grid>
          </Border>
        </TabItem>

        <TabItem x:Name="_trapsTab" Header="Traps">
          <Border Style="{StaticResource PanelBorder}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,20,0">
                  <TextBlock x:Name="_trapsTitle" Text="Traps" Style="{StaticResource SectionTitle}"/>
                  <TextBlock x:Name="_trapsMeta" Text="Edit conditions, thresholds, and enabled state." Style="{StaticResource SectionMeta}"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                  <Button x:Name="_moveTrapUpButton"
                          Content="^  Up"
                          Style="{StaticResource GhostButton}"
                          ToolTip="Move selected trap rows up. Alt+Up also works."
                          Margin="0,0,8,0"
                          Click="MoveTrapUp_Click"/>
                  <Button x:Name="_moveTrapDownButton"
                          Content="v  Down"
                          Style="{StaticResource GhostButton}"
                          ToolTip="Move selected trap rows down. Alt+Down also works."
                          Margin="0,0,8,0"
                          Click="MoveTrapDown_Click"/>
                  <Button x:Name="_addTrapButton"
                          Content="+  Add row"
                          Style="{StaticResource AppButton}"
                          Margin="0,0,8,0"
                          Click="AddTrap_Click"/>
                  <Button x:Name="_deleteTrapButton"
                          Content="-  Delete"
                          Style="{StaticResource GhostButton}"
                          Click="DeleteTrap_Click"/>
                </StackPanel>
              </Grid>

              <DataGrid x:Name="_trapsGrid"
                        Grid.Row="2"
                        AlternationCount="2"/>
            </Grid>
          </Border>
        </TabItem>

        <TabItem x:Name="_projectTab" Header="Project / Connection">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="1*"/>
              </Grid.ColumnDefinitions>

              <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="175"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>

                  <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                    <TextBlock x:Name="_projectSectionTitle" Text="Project" Style="{StaticResource SectionTitle}"/>
                    <TextBlock x:Name="_projectSectionMeta" Text="Basic information passed to the mobile app." Style="{StaticResource SectionMeta}"/>
                  </StackPanel>

                  <TextBlock x:Name="_projectNameLabel" Grid.Row="2" Grid.Column="0" Text="Project name" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <TextBox x:Name="_projectName" Grid.Row="2" Grid.Column="1" Text="PLC QR Project" Margin="0,4,0,4"/>

                  <TextBlock x:Name="_vendorLabel" Grid.Row="3" Grid.Column="0" Text="Vendor" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <ComboBox x:Name="_vendor" Grid.Row="3" Grid.Column="1" Margin="0,4,0,4" ItemTemplate="{StaticResource UppercaseComboBoxItemTemplate}"/>

                  <TextBlock x:Name="_modelLabel" Grid.Row="4" Grid.Column="0" Text="CPU model" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <ComboBox x:Name="_model" Grid.Row="4" Grid.Column="1" Margin="0,4,0,4"/>

                  <TextBlock x:Name="_keyenceModeLabel" Grid.Row="5" Grid.Column="0" Text="KEYENCE display" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <ComboBox x:Name="_keyenceMode" Grid.Row="5" Grid.Column="1" Margin="0,4,0,4" ItemTemplate="{StaticResource UppercaseComboBoxItemTemplate}"/>

                  <TextBlock x:Name="_supportedDevicesLabel" Grid.Row="6" Grid.Column="0" Text="Supported devices" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <TextBlock x:Name="_supportedDevicesText"
                             Grid.Row="6"
                             Grid.Column="1"
                             Foreground="{StaticResource TextMuted}"
                             TextWrapping="Wrap"
                             Margin="0,6,0,6"/>
                </Grid>
              </Border>

              <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="175"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>

                  <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                    <TextBlock x:Name="_connectionSectionTitle" Text="Connection" Style="{StaticResource SectionTitle}"/>
                    <TextBlock x:Name="_connectionSectionMeta" Text="PLC communication settings." Style="{StaticResource SectionMeta}"/>
                  </StackPanel>

                  <TextBlock x:Name="_connectionModeLabel" Grid.Row="2" Grid.Column="0" Text="Connection mode" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <ComboBox x:Name="_connectionMode" Grid.Row="2" Grid.Column="1" Margin="0,4,0,4" ItemTemplate="{StaticResource UppercaseComboBoxItemTemplate}"/>

                  <TextBlock x:Name="_hostLabel" Grid.Row="3" Grid.Column="0" Text="IP address" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <TextBox x:Name="_host" Grid.Row="3" Grid.Column="1" Text="192.168.250.100" Margin="0,4,0,4"/>

                  <TextBlock x:Name="_portLabel" Grid.Row="4" Grid.Column="0" Text="Port" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <TextBox x:Name="_port" Grid.Row="4" Grid.Column="1" Text="1025" Margin="0,4,0,4"/>

                  <TextBlock x:Name="_transportLabel" Grid.Row="5" Grid.Column="0" Text="Transport" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <ComboBox x:Name="_transport" Grid.Row="5" Grid.Column="1" Margin="0,4,0,4" ItemTemplate="{StaticResource UppercaseComboBoxItemTemplate}"/>

                  <TextBlock x:Name="_intervalLabel" Grid.Row="6" Grid.Column="0" Text="Polling interval ms" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <TextBox x:Name="_interval" Grid.Row="6" Grid.Column="1" Text="500" Margin="0,4,0,4"/>

                  <TextBlock x:Name="_timeoutLabel" Grid.Row="7" Grid.Column="0" Text="Timeout ms" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <TextBox x:Name="_timeout" Grid.Row="7" Grid.Column="1" Text="2000" Margin="0,4,0,4"/>

                  <TextBlock x:Name="_networkLabel" Grid.Row="8" Grid.Column="0" Text="Network" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <TextBox x:Name="_network" Grid.Row="8" Grid.Column="1" Text="0" Margin="0,4,0,4"/>

                  <TextBlock x:Name="_stationLabel" Grid.Row="9" Grid.Column="0" Text="Station" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <TextBox x:Name="_station" Grid.Row="9" Grid.Column="1" Text="255" Margin="0,4,0,4"/>

                  <TextBlock x:Name="_moduleIoLabel" Grid.Row="10" Grid.Column="0" Text="Module IO" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <TextBox x:Name="_moduleIo" Grid.Row="10" Grid.Column="1" Text="0x03FF" Margin="0,4,0,4"/>

                  <TextBlock x:Name="_multidropLabel" Grid.Row="11" Grid.Column="0" Text="Multidrop" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <TextBox x:Name="_multidrop" Grid.Row="11" Grid.Column="1" Text="0x00" Margin="0,4,0,4"/>

                  <TextBlock x:Name="_remotePasswordLabel" Grid.Row="12" Grid.Column="0" Text="Remote password" Style="{StaticResource FormLabel}" Margin="0,6,14,6"/>
                  <PasswordBox x:Name="_remotePassword" Grid.Row="12" Grid.Column="1" Margin="0,4,0,4"/>
                </Grid>
              </Border>
            </Grid>
          </ScrollViewer>
        </TabItem>
      </TabControl>
    </Grid>

    <Grid x:Name="_qrView"
          Grid.Row="2"
          Visibility="Collapsed"
          Background="{StaticResource QrStageBg}">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Margin="24">
        <Border Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource BorderSoft}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="28">
          <Viewbox Stretch="Uniform" StretchDirection="Both">
            <Border Background="White"
                    BorderBrush="{StaticResource BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24">
              <Image x:Name="_qrImage"
                     Width="900"
                     Height="900"
                     Stretch="Uniform"
                     RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Border>
          </Viewbox>
        </Border>
      </Grid>

      <Border Grid.Row="1"
              Background="{StaticResource HeaderBg}"
              BorderBrush="{StaticResource BorderSoft}"
              BorderThickness="0,1,0,0"
              Padding="24,12">
        <TextBlock x:Name="_qrMeta"
                   Foreground="{StaticResource TextMuted}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"/>
      </Border>
    </Grid>

    <!-- Row 3: status bar -->
    <Border Grid.Row="3"
            Background="{StaticResource HeaderBg}"
            BorderBrush="{StaticResource BorderSoft}"
            BorderThickness="0,1,0,0"
            Padding="16,0">
      <DockPanel LastChildFill="True">
        <TextBlock x:Name="_summaryText"
                   DockPanel.Dock="Right"
                   Foreground="{StaticResource TextMuted}"
                   VerticalAlignment="Center"
                   Margin="20,0,0,0"/>
        <TextBlock x:Name="_statusText"
                   Text="Ready"
                   Foreground="{StaticResource TextMuted}"
                   VerticalAlignment="Center"/>
      </DockPanel>
    </Border>
  </Grid>
</Window>
