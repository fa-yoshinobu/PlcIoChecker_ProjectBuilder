<Window x:Class="PlcIoCheckerQr.Wpf.Windows.PastePreviewWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paste preview"
        Width="860"
        Height="560"
        MinWidth="640"
        MinHeight="400"
        Icon="/icon.ico"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBg}"
        Foreground="{StaticResource TextMain}">

  <Window.Resources>
    <SolidColorBrush x:Key="PasteOkBg" Color="#E5F5EC"/>
    <SolidColorBrush x:Key="PasteOkFg" Color="#0E7A46"/>
    <SolidColorBrush x:Key="PasteErrorBg" Color="#FCE8E6"/>
    <SolidColorBrush x:Key="PasteErrorFg" Color="#B42318"/>
    <SolidColorBrush x:Key="PasteSkipBg" Color="#EDF1F0"/>
    <SolidColorBrush x:Key="PasteSkipFg" Color="#5D6B67"/>
    <SolidColorBrush x:Key="PasteErrorRowBg" Color="#FDF3F2"/>
    <SolidColorBrush x:Key="PasteSkipRowBg" Color="#F5F8F7"/>

    <!-- Status badge shown in the Status column -->
    <DataTemplate x:Key="StatusCellTemplate">
      <Border x:Name="Badge"
              CornerRadius="10"
              Padding="10,3"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              Background="{StaticResource PasteOkBg}">
        <TextBlock x:Name="BadgeText"
                   Text="{Binding Status}"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource PasteOkFg}"/>
      </Border>
      <DataTemplate.Triggers>
        <DataTrigger Binding="{Binding Kind}" Value="error">
          <Setter TargetName="Badge" Property="Background" Value="{StaticResource PasteErrorBg}"/>
          <Setter TargetName="BadgeText" Property="Foreground" Value="{StaticResource PasteErrorFg}"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding Kind}" Value="skip">
          <Setter TargetName="Badge" Property="Background" Value="{StaticResource PasteSkipBg}"/>
          <Setter TargetName="BadgeText" Property="Foreground" Value="{StaticResource PasteSkipFg}"/>
        </DataTrigger>
      </DataTemplate.Triggers>
    </DataTemplate>

    <Style x:Key="LineCellTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ErrorCellTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource PasteErrorFg}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin" Value="0,6"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0"
            Background="{StaticResource HeaderBg}"
            BorderBrush="{StaticResource BorderSoft}"
            BorderThickness="0,0,0,1"
            Padding="20,14">
      <StackPanel>
        <TextBlock x:Name="TitleTextBlock" Style="{StaticResource SectionTitle}"/>
        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
          <Border Background="{StaticResource PasteOkBg}" CornerRadius="10" Padding="10,3" Margin="0,0,8,0">
            <TextBlock x:Name="OkCountText"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PasteOkFg}"/>
          </Border>
          <Border Background="{StaticResource PasteErrorBg}" CornerRadius="10" Padding="10,3" Margin="0,0,8,0">
            <TextBlock x:Name="ErrorCountText"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PasteErrorFg}"/>
          </Border>
          <Border Background="{StaticResource PasteSkipBg}" CornerRadius="10" Padding="10,3">
            <TextBlock x:Name="SkipCountText"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PasteSkipFg}"/>
          </Border>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Preview rows -->
    <DataGrid x:Name="PreviewGrid"
              Grid.Row="1"
              Margin="20,14"
              IsReadOnly="True"
              CanUserAddRows="False"
              SelectionMode="Extended"
              SelectionUnit="FullRow"
              HeadersVisibility="Column"
              RowHeaderWidth="0"
              RowHeight="NaN"
              MinRowHeight="36">
      <DataGrid.RowStyle>
        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
          <Style.Triggers>
            <DataTrigger Binding="{Binding Kind}" Value="error">
              <Setter Property="Background" Value="{StaticResource PasteErrorRowBg}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Kind}" Value="skip">
              <Setter Property="Background" Value="{StaticResource PasteSkipRowBg}"/>
              <Setter Property="Foreground" Value="{StaticResource PasteSkipFg}"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </DataGrid.RowStyle>
    </DataGrid>

    <!-- Footer -->
    <Border Grid.Row="2"
            Background="{StaticResource HeaderBg}"
            BorderBrush="{StaticResource BorderSoft}"
            BorderThickness="0,1,0,0"
            Padding="20,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="HintTextBlock"
                   Style="{StaticResource SectionMeta}"
                   VerticalAlignment="Center"
                   Margin="0,0,16,0"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button x:Name="CancelButton"
                  Style="{StaticResource AppButton}"
                  IsCancel="True"
                  Margin="0,0,10,0"
                  Click="Cancel_Click"/>
          <Button x:Name="ImportButton"
                  Style="{StaticResource PrimaryButton}"
                  IsDefault="True"
                  Click="Import_Click"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
